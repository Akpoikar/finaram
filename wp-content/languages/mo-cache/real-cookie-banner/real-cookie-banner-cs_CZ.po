#. Plugin Name of the plugin
#: index.php
msgid "Real Cookie Banner"
msgstr "Real Cookie Banner"

#. Plugin URI of the plugin
#: index.php inc/view/Banner.php:270
msgid "https://devowl.io/wordpress-real-cookie-banner/"
msgstr "https://devowl.io/wordpress-real-cookie-banner/"

#. Description of the plugin
#: index.php
msgid ""
"Obtain GDPR (DSGVO) and ePrivacy (EU cookie law) compliant opt-in consent. "
"Find cookies and fill all legal information in your cookie banner. More than "
"just a cookie notice!"
msgstr ""
"Získejte opt-in souhlas s přihlášením v souladu s GDPR a ePrivacy (zákon "
"Evropské unie týkající se souborů cookie). Vyhledejte soubory cookie a "
"vyplňte v cookie banneru všechny právní informace. Více než jen oznámení o "
"souborech cookie!"

#. Author of the plugin
#: index.php
msgid "devowl.io"
msgstr "devowl.io"

