{"translation-revision-date":"2023-11-22 17:13:38+0000","generator":"WPML String Translation 3.2.8","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","plural-forms":"nplurals=2; plural=n != 1;","lang":""},"Sending for translation":["\u041e\u0442\u043f\u0440\u0430\u0432\u043a\u0430 \u043d\u0430 \u043f\u0435\u0440\u0435\u0432\u043e\u0434"],"Connecting to WPML\u2019s Advanced Translation Editor":["\u041f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435 \u043a \u0420\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u043d\u043e\u043c\u0443 \u0440\u0435\u0434\u0430\u043a\u0442\u043e\u0440\u0443 \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u0430 WPML"],"Try again":["\u041f\u043e\u0432\u0442\u043e\u0440\u0438\u0442\u044c \u043f\u043e\u043f\u044b\u0442\u043a\u0443"],"You don't have the rights to review this language":["\u0423 \u0432\u0430\u0441 \u043d\u0435\u0442 \u043f\u0440\u0430\u0432 \u0434\u043b\u044f \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0438 \u043d\u0430 \u044d\u0442\u043e\u043c \u044f\u0437\u044b\u043a\u0435."],"translations":["\u041f\u0435\u0440\u0435\u0432\u043e\u0434\u044b"],"left in the queue":["\u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u0432 \u043e\u0447\u0435\u0440\u0435\u0434\u0438"],"Translation on hold":["\u041f\u0435\u0440\u0435\u0432\u043e\u0434 \u043f\u0440\u0438\u043e\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d"],"No translations in the queue":["\u041d\u0435\u0442 \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u0432 \u0432 \u043e\u0447\u0435\u0440\u0435\u0434\u0438"],"%d translations left":["\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u0432: %d"],"%d min remaining":["\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c %d \u043c\u0438\u043d."],"less than 1 min remaining":["\u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c \u043c\u0435\u043d\u0435\u0435 1 \u043c\u0438\u043d."],"Automatic translation status":["\u0421\u043e\u0441\u0442\u043e\u044f\u043d\u0438\u