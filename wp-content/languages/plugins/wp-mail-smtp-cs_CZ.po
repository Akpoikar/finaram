#. documentation about custom domains.
#: src/Providers/Sendlayer/Options.php:151
msgid "You will need to register your own domain first on the <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer dashboard</a> to change it here. Check our <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">documentation</a> on how to add a custom domain."
msgstr "Abyste zde mohli doménu změnit, musíte si nejprve zaregistrovat vlastní doménu na <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">řídicím panelu SendLayer</a>. Podívejte se do naší <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">dokumentace</a>, kde najdete návod, jak přidat vlastní doménu."

#: src/Providers/Sendlayer/Options.php:144
msgid "This is a shared domain created for you via SendLayer Connect."
msgstr "Toto je sdílená doména, která pro vás byla vytvořena prostřednictvím služby SendLayer Connect."

#: src/Providers/Sendlayer/Options.php:125
msgid "Connect manually with API Key"
msgstr "Připojit se ručně pomocí klíče API"

#: src/Providers/Sendlayer/Options.php:105
msgid "Please save this additional connection first to use Quick Connect or enter an API Key manually."
msgstr "Nejprve si prosím uložte toto další připojení, abyste mohli použít funkci Rychlé připojení, nebo zadejte klíč API ručně."

#. translators: %1$s - URL to sendlayer.com; %2$s - URL to SendLayer
#. documentation on wpmailsmtp.com.
#: src/Providers/Sendlayer/Options.php:42
msgid "<strong><a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer</a> is our #1 recommended mailer.</strong> It offers affordable pricing and is easy to set up, which makes it an excellent option for WordPress sites. With SendLayer, your domain will be authenticated so all your outgoing emails reach your customers' inboxes. Our detailed <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">documentation</a> will walk you through the entire process, start to finish. <span class=\"wp-mail-smtp-text-blue wp-mail-smtp-text-italic\">When you sign up for a free trial, you can send your first emails at no charge.</span>"
msgstr "<strong><a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer</a> je náš nejvíce doporučovaný nástroj pro rozesílání e-mailů.</strong> Nabízí příznivé ceny a snadné nastavení, což z něj činí vynikající volbu pro weby na platformě WordPress. Díky SendLayer bude vaše doména ověřena, takže všechny vaše odchozí e-maily dorazí do schránek vašich zákazníků. Naše podrobná <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">dokumentace</a> vás provede celým procesem od začátku do konce. <span class=\"wp-mail-smtp-text-blue wp-mail-smtp-text-italic\">Když se zaregistrujete k bezplatné zkušební verzi, můžete odeslat své první e-maily zcela zdarma.</span>"

