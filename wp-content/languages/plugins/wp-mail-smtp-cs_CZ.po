#: src/Providers/Sendlayer/QuickConnect.php:608
msgid "Dismiss"
msgstr "Odmítnout"

#: src/Providers/Sendlayer/QuickConnect.php:830
msgid "Something went wrong while connecting to SendLayer. Please try again, or contact support and provide the error code."
msgstr "Při připojování k SendLayer došlo k chybě. Zkuste to prosím znovu, nebo se obraťte na podporu a uveďte kód chyby."

#. translators: %1$s - URL to SendLayer app; %2$s - URL to documentation.
#: src/Providers/Sendlayer/QuickConnect.php:681
msgid "You can customize your From Email by adding your own domain first on the <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer dashboard</a>. Check our <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">documentation</a> on how to add a custom domain."
msgstr "Adresu odesílatele si můžete přizpůsobit tak, že si nejprve přidáte vlastní doménu v <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferrer\">řídicím panelu SendLayer</a>. Podívejte se do naší <a href=\"%2$s\" target=\"_blank\" rel=\"noopener noreferrer\">dokumentace</a>, kde najdete návod, jak přidat vlastní doménu."

#: src/Providers/Sendlayer/QuickConnect.php:656
msgid "From Email Address"
msgstr "Z e-mailové adresy"

#: src/Providers/Sendlayer/QuickConnect.php:597
msgid "Setup SendLayer"
msgstr "Nastavení SendLayer"

#. translators: %s - URL to SendLayer.
#: src/Providers/Sendlayer/QuickConnect.php:580
msgid "You're using the default WordPress mailer, which often lands in spam! Switch to <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer</a>, our recommended mailer, and send your <strong>first 200 emails for free with just a few clicks!</strong>"
msgstr "Používáte výchozí poštovní modul WordPressu, jehož zprávy často končí ve složce se spamem! Přejděte na <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">SendLayer</a>, náš doporučený poštovní modul, a odešlete svých <strong>prvních 200 e-mailů zdarma pouhými několika kliknutími!</strong>"

#: src/Providers/Sendlayer/QuickConnect.php:573
msgid "Seems like you don't have a mailer setup yet!"
msgstr "Zdá se, že ještě nemáte nastavený e-mailový klient!"

#: src/Providers/Sendlayer/QuickConnect.php:483
msgid "SendLayer disconnect failed. The nonce is invalid. Please try again."
msgstr "Odpojení od SendLayer se nezdařilo. Jednorázový kód je neplatný. Zkuste to prosím znovu."

#: src/Providers/Sendlayer/QuickConnect.php:474
msgid "SendLayer disconnect failed. You do not have permission to perform this action."
msgstr "Odpojení služby SendLayer se nezdařilo. Nemáte oprávnění k provedení této akce."

#: src/Providers/Sendlayer/QuickConnect.php:444
msgid "SendLayer connection failed. Your connection code has expired. Please try again."
msgstr "Připojení k SendLayer se nezdařilo. Platnost vašeho připojovacího kódu vypršela. Zkuste to prosím znovu."

#: src/Providers/Sendlayer/QuickConnect.php:443
msgid "SendLayer connection failed. Too many attempts. Please wait a few minutes and try again."
msgstr "Připojení k SendLayer se nezdařilo. Došlo k příliš mnoha pokusům. Počkejte prosím několik minut a zkuste to znovu."

#: src/Providers/Sendlayer/QuickConnect.php:442
msgid "SendLayer connection failed. Your session has expired. Please try again."
msgstr "Připojení k SendLayer se nezdařilo. Vaše relace vypršela. Zkuste to prosím znovu."

#: src/Providers/Sendlayer/QuickConnect.php:441
msgid "SendLayer connection failed. You do not have permission to perform this action."
msgstr "Připojení k SendLayer se nezdařilo. Nemáte oprávnění k provedení této akce."

#: src/Providers/Sendlayer/QuickConnect.php:432
msgid "SendLayer connected successfully! You can now send emails through SendLayer."
msgstr "SendLayer byl úspěšně připojen! Nyní můžete odesílat e-maily prostřednictvím SendLayer."

#: src/Providers/Sendlayer/QuickConnect.php:414
msgid "SendLayer disconnected successfully."
msgstr "SendLayer se úspěšně odpojil."

#: src/Providers/Sendlayer/QuickConnect.php:66
#: src/Providers/Sendlayer/QuickConnect.php:520
